# Committed safe defaults for the manual HydraCache sandbox.
#
# This file intentionally contains only non-secret demo settings: profile,
# bind address, SQLite file path, and the local Docker Compose Postgres URL.
# Override values with CLI flags for one-off checks.

HYDRACACHE_SANDBOX_PROFILE=memory
HYDRACACHE_SANDBOX_BIND=127.0.0.1:3000
HYDRACACHE_SANDBOX_SQLITE_PATH=target/hydracache-sandbox.sqlite
HYDRACACHE_SANDBOX_DATABASE_URL=postgres://hydracache:hydracache@127.0.0.1:54329/hydracache

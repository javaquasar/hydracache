# Reference profile for the committed `.env` sandbox defaults.
#
# Supported profiles:
# - memory
# - sqlite-memory
# - sqlite-file
# - postgres-docker
#
# CLI flags override these values, so this file is a convenient reference for
# switching the committed demo profile.

HYDRACACHE_SANDBOX_PROFILE=memory
HYDRACACHE_SANDBOX_BIND=127.0.0.1:3000
HYDRACACHE_SANDBOX_SQLITE_PATH=target/hydracache-sandbox.sqlite

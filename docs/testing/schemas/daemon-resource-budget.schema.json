{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hydracache.dev/schemas/testing/daemon-resource-budget-v1.json",
  "title": "HydraCache daemon resource budget evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "release",
    "seed",
    "platform",
    "budget",
    "baseline",
    "peak",
    "final_sample",
    "samples"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "release": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "seed": { "type": "integer", "minimum": 0 },
    "platform": { "type": "string", "minLength": 1 },
    "budget": { "$ref": "#/$defs/budget" },
    "baseline": { "$ref": "#/$defs/sample" },
    "peak": { "$ref": "#/$defs/sample" },
    "final_sample": { "$ref": "#/$defs/sample" },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sample" }
    }
  },
  "$defs": {
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_child_delta",
        "max_connection_delta",
        "max_held_snapshot_messages",
        "max_rss_growth_kib",
        "max_fd_growth"
      ],
      "properties": {
        "max_child_delta": { "type": "integer", "minimum": 0 },
        "max_connection_delta": { "type": "integer", "minimum": 0 },
        "max_held_snapshot_messages": { "type": "integer", "minimum": 0 },
        "max_rss_growth_kib": { "type": "integer", "minimum": 0 },
        "max_fd_growth": { "type": "integer", "minimum": 0 }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "running_children",
        "tracked_connections",
        "held_snapshot_messages"
      ],
      "properties": {
        "running_children": { "type": "integer", "minimum": 0 },
        "tracked_connections": { "type": "integer", "minimum": 0 },
        "held_snapshot_messages": { "type": "integer", "minimum": 0 },
        "rss_kib": { "type": "integer", "minimum": 0 },
        "open_fds": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
